{
  "expo": {
    "name": "minibook",
    "slug": "minibook",
    "scheme": "minibook",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-document-picker",
      "expo-sqlite",
      "expo-dev-client",
      "@config-plugins/react-native-blob-util",
      "@config-plugins/react-native-pdf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaide.minibook"
    },
    "android": {
      "package": "com.jaide.minibook"
    }
  }
}
